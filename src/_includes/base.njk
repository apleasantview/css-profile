<!DOCTYPE html>
<html lang="en">
<baseline-head></baseline-head>
  <body>
    <header>
      <div class="wrapper">{% include "components/c-navigation.njk" %}</div>
    </header>

    <main class="page">
      <div class="wrapper">
        {% include "components/c-breadcrumbs.njk" %}
      </div>
      <div class="flow wrapper">
        <h1>{{ title }}</h1>
        {{ content | safe }}
      </div>
      <div class="wrapper">
        {% if section and "/index." not in page.inputPath %}
          <p>
            <a href="/{{ section | join('/') }}/" style="display: block; line-height: 1.2; vertical-align: middle; text-underline-offset: 0.4em; margin-block: var(--space-m);">
              <span>&#8592;</span>&nbsp;Back to {{ section | safe | title }}
            </a>
          </p>
        {% endif %}
      </div>
    </main>

    <footer>
      <div class="wrapper">
        {% include "components/c-footer.njk" %}
      </div>
    </footer>

    <script>
      /* Theme switch: cycles system -> light -> dark, reading the same
       * data-theme contract the CSS reads. system means follow the OS. */
      (function () {
        var btn = document.querySelector('[data-theme-toggle]');
        if (!btn) return;
        var modes = ['system', 'light', 'dark'];
        var current = function () { return localStorage.getItem('theme') || 'system'; };
        var paint = function () { btn.textContent = 'theme — ' + current(); };
        btn.addEventListener('click', function () {
          var next = modes[(modes.indexOf(current()) + 1) % modes.length];
          if (next === 'system') {
            delete document.documentElement.dataset.theme;
            localStorage.removeItem('theme');
          } else {
            document.documentElement.dataset.theme = next;
            localStorage.setItem('theme', next);
          }
          paint();
        });
        paint();
      })();
    </script>
  </body>
</html>
