<!--
  Specimen-layout styles, shared by the lexicon's vocabulary pages: a harness
  concern, not part of profile/ or document/. They consume the vocabulary's own
  tokens on purpose — the menu eats its own cooking.
-->
<style>
  .vocab-table td.is-missing {
    color: var(--color-danger-text);
    text-decoration: line-through dotted;
  }
  .vocab-note {
    color: var(--color-text-muted);
    font-style: italic;
  }
  .overflow-x {
    overflow-x: auto;
    padding-block: var(--space-s);
  }
  .overflow-x table {
    margin-block: var(--space-xs);
  }
  /* Token names stay on one line, so a too-wide table scrolls inside the
     wrapper instead of cramming the page; descriptions still wrap. */
  .overflow-x td {
    white-space: nowrap;
  }
</style>
